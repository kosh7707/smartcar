# AEGIS S2 Backend — 환경변수
# 복사 후 .env로 이름 변경하여 사용

# 서버 포트 (기본: 3000)
PORT=3000

# CORS 허용 오리진 — 쉼표 구분 (기본: http://localhost:5173)
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# S7 LLM Gateway URL (기본: http://localhost:8000)
LLM_GATEWAY_URL=http://localhost:8000

# LLM 동시 요청 수 (기본: 4)
# LLM_CONCURRENCY=4

# S3 Analysis Agent URL (기본: http://localhost:8001)
# ANALYSIS_AGENT_URL=http://localhost:8001

# S4 SAST Runner URL (기본: http://localhost:9000)
# SAST_RUNNER_URL=http://localhost:9000

# S5 Knowledge Base URL (기본: http://localhost:8002)
# KB_URL=http://localhost:8002

# S3 Build Agent URL (기본: http://localhost:8003)
# BUILD_AGENT_URL=http://localhost:8003

# 소스코드 업로드 디렉토리 (기본: <project-root>/uploads)
# UPLOADS_DIR=../../../uploads

# SQLite DB 경로 (기본: services/backend/aegis.db)
# DB_PATH=./aegis.db

# 로그 디렉토리 (기본: <project-root>/logs)
# LOG_DIR=../../../../logs

# 로그 레벨: debug(20), info(30), warn(40), error(50), fatal(60) (기본: info)
# LOG_LEVEL=info

# 인증 필수 여부 (기본: false — soft auth 모드)
# AUTH_REQUIRED=false

# 초기 관리자 계정 (최초 기동 시 자동 생성)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin1234

# 로컬 mock-to-real 브릿지용 auth dev fixture/org-admin seed (기본: NODE_ENV=development|test 에서만 활성)
# AEGIS_AUTH_DEV_FIXTURES=true

# 로컬 mock-to-real 브릿지용 password-reset dev token 조회 route 활성화 (기본: NODE_ENV=development|test 에서만 활성)
# AEGIS_AUTH_DEV_PASSWORD_RESET_BRIDGE=true

# 위 fixture org-admin 공통 비밀번호 (기본: Admin1234!)
# AEGIS_AUTH_DEV_ADMIN_PASSWORD=Admin1234!
