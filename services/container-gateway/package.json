{
  "name": "@aegis/container-gateway",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:upload-compile": "bash scripts/smoke-upload-compile.sh",
