    "exec:upload-and-run": "bash scripts/upload-and-exec.sh"
  },
  "dependencies": {
    "express": "^5.2.1",
    "multer": "^2.0.2",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.1",
    "@types/node": "^24.10.1"
  }
}
