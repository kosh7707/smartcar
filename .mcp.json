{
  "mcpServers": {
    "aegis-static-wiki": {
      "command": "node",
      "args": ["../aegis-static-wiki/tools/wiki/mcpServer.js"],
      "cwd": "../aegis-static-wiki"
    },
    "stitch": {
      "command": "stitch-mcp",
      "args": ["proxy"]
    },
    "log-analyzer": {
      "command": "./tools/log-analyzer/.venv/bin/python",
      "args": ["./tools/log-analyzer/server.py"],
      "cwd": ".",
      "env": {
        "LOGS_DIR": "./logs"
      }
    }
  }
}
